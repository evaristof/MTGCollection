<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.1"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.1 https://maven.apache.org/xsd/assembly-2.1.1.xsd">
    <id>dist</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>mtgcollection-${project.version}</baseDirectory>

    <files>
        <!-- The Spring Boot fat jar (produced by spring-boot-maven-plugin
             during the `package` phase, before this assembly runs). -->
        <file>
            <source>${project.build.directory}/${project.build.finalName}.jar</source>
            <outputDirectory>.</outputDirectory>
            <destName>mtgcollection.jar</destName>
        </file>
        <file>
            <source>${project.basedir}/src/assembly/launchers/start.bat</source>
            <outputDirectory>.</outputDirectory>
            <lineEnding>dos</lineEnding>
        </file>
        <file>
            <source>${project.basedir}/src/assembly/launchers/start.sh</source>
            <outputDirectory>.</outputDirectory>
            <fileMode>0755</fileMode>
            <lineEnding>unix</lineEnding>
        </file>
        <file>
            <source>${project.basedir}/src/assembly/launchers/README-dist.txt</source>
            <outputDirectory>.</outputDirectory>
        </file>
    </files>
</assembly>
